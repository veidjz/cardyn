{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cardyn",
  "version": "0.1.0",
  "identifier": "com.skoolab.cardyn",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cardyn",
        "width": 778,
        "height": 550,
        "center": true,
        "minWidth": 540,
        "minHeight": 440,
        "resizable": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
